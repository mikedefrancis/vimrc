" ============================================================================
" PLUGIN CONFIGURATION
" ============================================================================

" Use the Molokai colorscheme.
colorscheme molokai

" ==== Easymotion ====
" Disable default EasyMotion mappings so custom mappings can be used instead.
let g:EasyMotion_do_mapping = 0
" Make EasyMotion searches smart-case aware.
let g:EasyMotion_smartcase = 1
" nmap f <Plug>(easymotion-s)

" Configure fzf to avoid preview windows for a leaner UI.
let g:fzf_vim = {}
let g:fzf_vim.buffers_options = '--no-preview'
let g:fzf_preview_window = []
let g:fzf_marks_options = '--no-preview --ansi --layout=reverse --delimiter=\s\+ --with-nth=1..'

" Window navigation with Ctrl+arrow keys from normal and insert mode.
nnoremap <silent> <C-Up> :wincmd k<CR>
nnoremap <silent> <C-Down> :wincmd j<CR>
nnoremap <silent> <C-Left> :wincmd h<CR>
nnoremap <silent> <C-Right> :wincmd l<CR>
inoremap <silent> <C-Up> <ESC>:wincmd k<CR>
inoremap <silent> <C-Down> <ESC>:wincmd j<CR>
inoremap <silent> <C-Left> <ESC>:wincmd h<CR>
inoremap <silent> <C-Right> <ESC>:wincmd l<CR>

" NERDCOMMENTER
" Add spaces after comment delimiters by default.
let g:NERDSpaceDelims = 1
" Use compact syntax for prettified multi-line comments.
let g:NERDCompactSexyComs = 1
" Align line-wise comment delimiters flush left.
let g:NERDDefaultAlign = 'left'
" Set Java to use alternate delimiters by default.
let g:NERDAltDelims_java = 1
" Add custom comment delimiters for C.
let g:NERDCustomDelimiters = { 'c': { 'left': '/**','right': '*/' } }
" Allow commenting and inverting empty lines.
let g:NERDCommentEmptyLines = 1
" Trim trailing whitespace when uncommenting.
let g:NERDTrimTrailingWhitespace = 1

" ============================================================================
" GENERAL EDITOR SETTINGS
" ============================================================================

" Enable syntax highlighting.
syntax enable

" Set a visual guide column and wrap/format width for text editing.
set colorcolumn=81
set textwidth=79
set formatoptions+=t

" Use UTF-8 and support common file formats.
set encoding=utf8
set ffs=unix,dos,mac

" Misc display and editing behavior.
set nowb
set showmatch
set lazyredraw
set noerrorbells
set novisualbell
set ai
set si
set wrap
" set wildmode
set expandtab
set background=dark
set guifont=Monospace\ 10
set fillchars+=vert:\$
set ruler
set hidden
set number
set laststatus=2
set smartindent
set st=4 sw=4 et
set shiftwidth=4
set tabstop=4
set softtabstop=4

" Remove GUI chrome where supported.
set guioptions-=m  " remove menu bar
set guioptions-=T  " remove toolbar
set guioptions-=r  " remove right-hand scroll bar
set guioptions-=L  " remove left-hand scroll bar

" Increase stored viminfo/history and keep useful title/status behavior.
set viminfo='100,<50,s10,h
" I AM COMMENTING OUT THIS LINE BECAUSE I WANT USER TO DECIDE SIZE OF VIM WINDOW
" :set lines=999 columns=999
set history=10000
set undolevels=1000
set title
set nobackup

" Make searches incremental and smart-case.
set ignorecase smartcase
set incsearch
set autoindent smartindent

" DANGERWILLROBINSON
set noswapfile

" Ack-related highlighting/preview toggles if ack is present.
let g:ackhighlight = 1
let g:ackpreview = 1

" Use semicolon as a quick alias for colon commands.
nnoremap ; :
" Set comma as the leader key.
let mapleader=","

" Use the system clipboard by default.
