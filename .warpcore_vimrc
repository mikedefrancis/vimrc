" ============ WARPCORE VIMRC ===========
" @Description
" WARPCORE is a heavily edited vim configuration.
"
" WARNING: You MUST add the following line to THE END of your .bashrc (or .zshrc).
" Note that my install scripts attempt to add this line to your .bashrc automatically:
"     stty -ixon
"
" This file has been reorganized and documented, while preserving the original
" functionality as much as possible. Commented-out code has been retained.

" ============================================================================
" HIGH-LEVEL KEY REFERENCE
" ============================================================================
"
" CONTROL KEY MAPPING:
" C-q: save and quit
" C-w: set working directory to current file's directory
" C-e: Open a new terminal (currently commented out below)
" C-r: Redo
" C-t: Copy line/selection into the custom k register
" C-y: open horizontal split
" C-a: leave insert/visual and return toward normal mode
" C-s: Save
" C-d: Delete character
" C-f: Find in file
" C-g: Start/stop recording macro
" C-h: Jump left window
" C-j: Jump down by 64 lines
" C-k: Jump up by 64 lines
" C-l: Jump right window
" C-z: Undo
" C-x: Cut
" C-c: Copy
" C-v: Paste
" C-b: Search open buffers with fzf
" C-m: Start/stop recording macro into register g
" Ctrl+{h,j,k,l}: custom movement/window navigation
" Ctrl+Left/Right/Up/Down: move between windows
"
" SHIFT KEY REMAPPING:
" S-`: Drop Nexus file to current path or open if existing
" S-1..S-0: bookmark-related helpers using shifted number keys
" S-q: save and quit
" S-w: vertical split and move into it
" S-p: set vim colors (currently commented out below)
" S-e: open a new tab
" S-r: search and replace prompt
" S-t: todo.txt
" S-y: git diff current file
" S-a: back in jump list
" S-s: forward-ish / tab behavior
" S-d: fuzzy file search from current directory
" S-f: ripgrep search in files
" S-g: fuzzy git status
" S-z: open terminal then run ls
" S-x: fuzzy open buffers
" S-c: fuzzy file history
" S-v: Enter visual mode
" S-b: next tab
" S-n: previous search result in file
" S-i: toggle search highlight
" S-Tab: unindent (visual mode)
"
" OTHER MAPPINGS FOR NORMAL MODE:
" a              insert mode
" i              toggle whitespace characters
" cd             change directory using :cd command
" cw             change word under cursor
" dd             cut line
" yy             run yapf formatting on the current file
" de             cut to end of current line
" dw             delete word under cursor
" mm             view man page
" bb             convert the loaded file to hex
" n/S-n: next/previous search result in file
" gg: search commit history tree graph
" gf: search commit history of current file
" fd: fzf search for text in all open buffers
" fg: search search history
" fc: search command history
" ff: search for text in current buffer using fzf BLines
" fh: find/highlight word under cursor using gd
" ``: goto current nexus and set it as the working directory
" cc: show current working directory
" cv: show full path to current file
" gt: goto top of file
" gb: goto bottom of file
" gs: goto first non-blank character of the line
" ge: goto end of current line's real text
" rr: paste contents stored to r register (stored via S-r / custom flows)
" Space toggle center-scroll
" ;     Enter command mode (:<command>)
" '     Run external command (:!<command>)
" ,     Leader
" ,c<Space> Toggle comment/uncomment selected line(s)
"
" STANDARD VIM COMMAND REFERENCE:
"  w/W       goto start of next word
"  e/E       goto end of next word
"  b/B       goto start of previous word
"  v         enter visual mode
"  V         enter visual line mode
"  :<number> goto line number
"  :Delete   delete file in buffer
"  :SudoEdit edit a file using sudo
"  :Find     use find and output results to quickfix window
"  :Chmod    change the permission of the current file
"
" PLUGINS:
"   I am using Vundle to install my plugins

" ============================================================================
" CORE VIM / VUNDLE BOOTSTRAP
" ============================================================================

" Use bash for all shell integration inside Vim (:!, :terminal, plugins, etc.).
set shell=/bin/bash

" Enable improved Vim behavior instead of Vi compatibility mode.
set nocompatible

" Allow local .vimrc/.exrc files and disable filetype detection until plugins load.
filetype off
set exrc

" Add Vundle itself to runtimepath and start plugin declaration.
set rtp+=~/.vim/bundle/Vundle.vim
call vundle#begin()

" ============================================================================
" PLUGINS
" ============================================================================

" Vundle manages the rest of the plugin list.
Plugin 'VundleVim/Vundle.vim'

" Plugin 'richardtz/vim-gpt'
" Plugin 'jackMort/ChatGPT.nvim'
" Plugin 'iberianpig/chatgpt.vim.git'
" Plugin 'terryma/vim-openai'

